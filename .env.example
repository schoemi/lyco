# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/lyco?schema=public"

# NextAuth.js (v5)
AUTH_SECRET="change-me-to-a-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_COOKIE_SECURE=true          # Set to "false" for HTTP-only staging environments
# Legacy aliases (still supported)
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI / LLM
OPENAI_API_KEY=sk-...          # Required for PDF song import
LLM_API_KEY=sk-...             # Required: API key for the LLM provider
LLM_API_URL=                   # Optional: Base URL for the LLM API (defaults to OpenAI)
LLM_MODEL=                     # Optional: Model name (defaults to gpt-4o-mini)

# Docker Deployment (docker-compose)
APP_PORT=3000                  # Optional: Host port for the app (default: 3000)
DB_PORT=5434                   # Optional: Host port for PostgreSQL (default: 5434)
APP_IMAGE=ghcr.io/schoemi/lyco:latest  # Optional: Override Docker image
